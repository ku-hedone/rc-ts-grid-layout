{
	"name": "@hedone/rc-ts-grid-layout",
	"version": "1.1.6",
	"repository": "git@github.com:ku-hedone/rc-ts-grid-layout.git",
	"description": "",
	"main": "cjs/index.js",
	"module": "esm/index.js",
	"types": "typings/index.d.ts",
	"files": [
		"cjs",
		"esm",
		"typings",
		"src",
		"LICENSE",
		"README.md"
	],
	"keywords": [
		"react",
		"hook",
		"typescript",
		"function component",
		"grid layout",
		"responsive"
	],
	"scripts": {
		"cjs": "tsc -p cjs.tsconfig.json",
		"esm": "tsc -p esm.tsconfig.json",
		"declare": "tsc -p declare.tsconfig.json",
		"build": "pnpm run check && pnpm run clean && pnpm run cjs && pnpm run esm && pnpm run declare && node cp-static.mjs",
		"clean": "rimraf cjs esm typings",
		"pre:build": "pnpm run clean",
		"update:patch": "pnpm version patch",
		"update:minor": "pnpm version minor",
		"update:major": "pnpm version major",
		"check": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:ui": "vitest --ui"
	},
	"author": "jackqian",
	"license": "MIT",
	"devDependencies": {
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/react": "^16.1.0",
		"@testing-library/user-event": "^14.5.2",
		"@vitejs/plugin-react-swc": "^4.3.1",
		"@vitest/coverage-v8": "^2.1.8",
		"@vitest/ui": "^2.1.8",
		"jsdom": "^25.0.1",
		"lodash": "^4.17.21",
		"react": ">=18.x.x",
		"react-dom": ">=18.x.x",
		"react-draggable": "^4.4.6",
		"react-resizable": "^3.0.5",
		"vitest": "^2.1.8"
	},
	"peerDependencies": {
		"lodash": "^4.17.21",
		"react": ">=18.x.x",
		"react-dom": ">=18.x.x",
		"react-draggable": "^4.4.6",
		"react-resizable": "^3.0.5"
	},
	"access": true
}
